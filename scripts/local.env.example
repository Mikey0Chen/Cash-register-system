DB_URL=jdbc:mysql://127.0.0.1:3306/cocktail_bar?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
DB_USERNAME=cocktail
DB_PASSWORD=cocktail123
JWT_SECRET=cash-register-local-secret
JWT_EXPIRATION=86400000
VITE_API_BASE_URL=/api
SERVER_PORT=8080

# Backend local startup:
# - jar: faster startup, auto-builds when backend source changed
# - maven: useful while actively developing backend code
BACKEND_RUN_MODE=jar

# Optional HikariCP tuning
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=0

# Keep the backend memory footprint small on low-spec servers
JAVA_OPTS=-Xms128m -Xmx256m -XX:+UseG1GC

# Optional Tomcat tuning
SERVER_TOMCAT_MAX_THREADS=50
SERVER_TOMCAT_MIN_SPARE_THREADS=5
